# .env.example — plantilla de variables de entorno del BACKEND.
#
# Copia este archivo a `.env` para tu entorno local, o define estas variables
# directamente en el dashboard de tu proveedor (Render → Environment) en producción.
#
# IMPORTANTE:
#   - NO subas tu `.env` real al repositorio (está en .gitignore). Solo esta plantilla.
#   - El backend NO carga `.env` automáticamente (no usa python-dotenv). En local, o bien
#     usas los valores por defecto, o exportas estas variables en tu shell antes de arrancar
#     uvicorn. En producción, Render las inyecta al proceso.
#   - Todas tienen un valor por defecto seguro para desarrollo; en producción define al menos
#     DATABASE_URL, GOOGLE_CLIENT_ID, AUTH_SECRET y CORS_ORIGINS.

# Cadena de conexión a la base de datos.
# Local (por defecto): SQLite en un archivo. Producción: Postgres (Internal Database URL de Render).
# Default: sqlite:///./horario.db
DATABASE_URL=

# Client ID de OAuth (Google Cloud Console). Si queda vacío, la autenticación se DESACTIVA
# (acceso abierto, útil para desarrollo y tests).
GOOGLE_CLIENT_ID=

# Secreto para firmar los JWT de sesión. OBLIGATORIO y aleatorio en producción.
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Default: dev-secret-no-usar-en-prod
AUTH_SECRET=

# Dominios de correo permitidos para iniciar sesión, separados por coma.
# Default: uandes.cl,miuandes.cl
ALLOWED_DOMAINS=uandes.cl,miuandes.cl

# Duración de la sesión en días. Default: 7
SESSION_DAYS=7

# Orígenes permitidos por CORS, separados por coma (además de localhost, que ya está incluido).
# En desarrollo no hace falta setearla. En producción: la URL del frontend.
# Ej: CORS_ORIGINS=https://tu-frontend.onrender.com
CORS_ORIGINS=
